# Container settings
CONTAINER_NAME=vpnsocksifier
BIND_ADDR=0.0.0.0

# SOCKS5 Proxy settings
SOCKS_PORT=1080
SOCKS_USER=proxyuser
SOCKS_PASS=proxypass

# VPN authentication (OpenVPN only, if config uses auth-user-pass)
VPN_USER=
VPN_PASS=

# VPN config path (directory containing VPN config files)
VPN_CONFIG_PATH=./config

# VPN config file (filename within VPN_CONFIG_PATH, auto-detected if empty)
VPN_CONFIG=

# DNS servers (comma-separated, applied after VPN connects)
DNS_SERVERS=1.1.1.1,8.8.8.8

# Kill switch (prevents traffic leaks if VPN drops)
KILL_SWITCH=true

# VPN log verbosity (OpenVPN: 0-11, default 3)
VPN_LOG_LEVEL=3

# Connection test
CONNECTION_TEST_URL=https://api.ipify.org
CONNECTION_TEST_TIMEOUT=60
